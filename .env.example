# RAG 系统环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== SiliconFlow API ====================
# 硅基流动 API 密钥（必需）
SILICONFLOW_API_KEY=your_api_key_here

# SiliconFlow API 基础 URL（可选，默认如下）
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ==================== 模型配置 ====================
# 嵌入模型（可选，默认：BAAI/bge-m3）
EMBEDDING_MODEL=BAAI/bge-m3

# Reranker 模型（可选，默认：BAAI/bge-reranker-v2-m3）
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# 是否启用 Reranker（可选，默认：true）
RERANKER_ENABLED=true

# Reranker 返回文档数量（可选，默认：3，范围：1-10）
RERANKER_TOP_N=3

# LLM 模型（可选，默认：Qwen/Qwen3-8B）
LLM_MODEL=Qwen/Qwen3-8B

# LLM 温度参数（可选，默认：0.0，范围：0.0-2.0）
LLM_TEMPERATURE=0.0

# ==================== 向量数据库 ====================
# Chroma 向量库持久化目录（可选，默认：./chroma_db）
CHROMA_PERSIST_DIR=./chroma_db

# ==================== 文档处理 ====================
# 分块策略（可选，默认：chinese）
# 可选值: fixed(固定字符), chinese(中文优化), markdown(Markdown结构), code(代码), parent_child(父子文档)
SPLIT_STRATEGY=chinese

# 文档切分块大小（可选，默认：1000，范围：100-5000）
DEFAULT_CHUNK_SIZE=1000

# 文档切分重叠大小（可选，默认：100，范围：0-1000）
DEFAULT_CHUNK_OVERLAP=100

# 是否自动检测内容类型（可选，默认：true）
# 启用后会根据内容自动选择最优的分块策略
AUTO_DETECT_CONTENT_TYPE=true

# ==================== Redis 缓存 ====================
# Redis 主机地址（可选，默认：localhost）
REDIS_HOST=localhost

# Redis 端口（可选，默认：6379）
REDIS_PORT=6379

# Redis 密码（可选）
REDIS_PASSWORD=

# Redis 数据库编号（可选，默认：0）
REDIS_DB=0

# 是否启用 Redis 缓存（可选，默认：true）
REDIS_ENABLED=true

# 向量查询缓存 TTL（秒，可选，默认：3600）
CACHE_TTL_QUERY=3600

# LLM 响应缓存 TTL（秒，可选，默认：86400）
CACHE_TTL_RESPONSE=86400

# ==================== 应用配置 ====================
# 应用监听地址（可选，默认：0.0.0.0）
APP_HOST=0.0.0.0

# 应用监听端口（可选，默认：8000）
APP_PORT=8000

# 工作进程数（可选，默认：1，范围：1-32）
# 生产环境建议设置为 CPU 核心数
WORKERS=4

# 日志级别（可选，默认：INFO，可选：DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# ==================== 并发控制 ====================
# 最大并发请求数（可选，默认：50，范围：1-1000）
MAX_CONCURRENT_REQUESTS=50

# ==================== 重试配置 ====================
# API 调用最大重试次数（可选，默认：3，范围：0-10）
MAX_RETRIES=3

# 重试延迟基数（秒，可选，默认：1.0）
RETRY_DELAY=1.0
